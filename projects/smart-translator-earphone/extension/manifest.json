{
  "manifest_version": 3,
  "name": "Smart Translator Earphone (companion)",
  "version": "0.2.0",
  "description": "Capture audio from a Chrome tab (YouTube, Netflix, meetings, …), transcribe it, translate it, and speak the translation in your ear. Free Google Translate is built in; YouTube uses zero-key captions, other tabs can use OpenAI/Google STT.",
  "permissions": ["tabCapture", "offscreen", "storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://api.openai.com/*",
    "https://speech.googleapis.com/*",
    "https://translate.googleapis.com/*",
    "https://*.youtube.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Smart Translator Earphone"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["lib/youtube-captions.js"],
      "matches": ["https://*.youtube.com/*"]
    }
  ],
  "minimum_chrome_version": "116"
}
