# Smart Translator Earphone — example environment variables
#
# Copy this file to `.env` (which is gitignored) and fill in the API keys
# you intend to use. The app runs in fully-functional DEMO MODE without any
# of these set — the demo providers return placeholder transcripts and
# translations so you can exercise the full UI without spending API quota.
#
# All variables MUST be prefixed with EXPO_PUBLIC_ so that they are inlined
# by the Metro bundler at build time. Do NOT put server-only secrets here;
# anything in this file is shipped to the client.

# Speech-to-Text providers
EXPO_PUBLIC_OPENAI_API_KEY=
EXPO_PUBLIC_GOOGLE_CLOUD_API_KEY=

# Translation providers
EXPO_PUBLIC_DEEPL_API_KEY=
# OPENAI_API_KEY (above) is reused for GPT-4 translation.

# Text-to-Speech providers
EXPO_PUBLIC_AZURE_TTS_KEY=
EXPO_PUBLIC_AZURE_TTS_REGION=westus
# GOOGLE_CLOUD_API_KEY (above) is reused for Google TTS.

# Default engine selection (overrides src/config/default-config.ts)
# Allowed values:
#   STT:         mock | whisper-cloud | google
#   Translation: mock | deepl | openai | google
#   TTS:         mock | azure | google
EXPO_PUBLIC_DEFAULT_STT_ENGINE=mock
EXPO_PUBLIC_DEFAULT_TRANSLATION_ENGINE=mock
EXPO_PUBLIC_DEFAULT_TTS_ENGINE=mock
