{
  "name": "smart-translator-earphone-app",
  "version": "0.2.0",
  "private": true,
  "description": "Smart Translator Earphone — Expo app (mobile + web). Epics 1–5: audio pipeline, STT, translation, TTS, conversation UI.",
  "main": "index.js",
  "scripts": {
    "android": "expo start --android",
    "export:web": "expo export --platform web",
    "ios": "expo start --ios",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint \"src/**/*.{ts,tsx}\"",
    "quality": "npm run typecheck && npm run lint && npm test",
    "start": "expo start",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit",
    "web": "expo start --web"
  },
  "jest": {
    "collectCoverageFrom": [
      "src/core/**/*.ts",
      "!src/core/**/*.test.ts",
      "!src/core/**/index.ts",
      "!src/core/audio/expo-audio-capture.ts",
      "!src/core/audio/web-audio-capture.ts",
      "!src/core/audio/platform-audio-factory.ts"
    ],
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "<rootDir>/src/core/**/*.test.ts"
    ]
  },
  "dependencies": {
    "@react-navigation/native": "^7.0.14",
    "@react-navigation/native-stack": "^7.2.0",
    "expo": "~52.0.23",
    "expo-av": "~15.0.1",
    "expo-constants": "~17.0.3",
    "expo-status-bar": "~2.0.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.5",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-web": "~0.19.13"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.30",
    "@types/react": "~18.3.12",
    "@typescript-eslint/eslint-plugin": "^7.4.0",
    "@typescript-eslint/parser": "^7.4.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "~5.3.3"
  }
}
